{
  "name": "gratonite-web",
  "description": "Gratonite web client — React/Vite SPA with real-time chat, voice, and federation support",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:vite": "vite build",
    "lint": "eslint . --max-warnings=250",
    "lint:a11y:strict": "eslint . --max-warnings=0",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:e2e": "playwright test tests/smoke.spec.ts",
    "smoke:check-env": "node ../../tools/check-production-smoke-env.mjs",
    "smoke:production": "playwright test --config=playwright.production.config.ts",
    "guard:placeholders": "node ../../tools/placeholder-guard.mjs",
    "validate:sw-precache": "node ../../tools/check-sw-precache.mjs",
    "verify:prod": "npm run build && npm run lint && npm run guard:placeholders"
  },
  "dependencies": {
    "@blocknote/core": "^0.47.2",
    "@blocknote/mantine": "^0.47.2",
    "@blocknote/react": "^0.47.2",
    "@gratonite/types": "workspace:*",
    "@sentry/react": "^10.45.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-virtual": "^3.13.19",
    "dompurify": "^3.3.2",
    "framer-motion": "^12.34.3",
    "gsap": "^3.14.2",
    "highlight.js": "^11.11.1",
    "jszip": "^3.10.1",
    "katex": "^0.16.38",
    "livekit-client": "^2.17.2",
    "lucide-react": "^0.575.0",
    "mermaid": "^11.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1",
    "socket.io-client": "^4.8.3",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.58.2",
    "@sentry/vite-plugin": "^5.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/katex": "^0.16.8",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^9.13.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "jsdom": "^26.1.0",
    "react-grab": "^0.1.25",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.9"
  }
}
