{
  "name": "@gratonite/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Gratonite mobile app (Expo + React Native)",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "doctor": "npx expo-doctor",
    "ios:prebuild": "expo prebuild --platform ios --no-install",
    "ios:sim": "expo run:ios",
    "eas:login": "pnpm dlx eas-cli@latest login",
    "eas:init": "pnpm dlx eas-cli@latest init",
    "eas:build:ios:dev": "pnpm dlx eas-cli@latest build --platform ios --profile development",
    "eas:build:ios:preview": "pnpm dlx eas-cli@latest build --platform ios --profile preview",
    "eas:build:ios:prod": "pnpm dlx eas-cli@latest build --platform ios --profile production",
    "eas:submit:ios:prod": "pnpm dlx eas-cli@latest submit --platform ios --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native/assets-registry": "0.74.87",
    "@react-navigation/bottom-tabs": "^7.15.2",
    "@react-navigation/native": "^7.1.31",
    "@react-navigation/native-stack": "^7.14.2",
    "expo": "^51.0.0",
    "expo-asset": "~10.0.10",
    "expo-blur": "^55.0.8",
    "expo-constants": "^16.0.2",
    "expo-dev-client": "~4.0.29",
    "expo-image-picker": "^55.0.9",
    "expo-linear-gradient": "^55.0.8",
    "expo-secure-store": "^55.0.8",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "^2.16.2",
    "react-native-safe-area-context": "^4.10.5",
    "react-native-screens": "^3.31.1",
    "react-native-webview": "^13.8.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "18.2.79",
    "debug": "^4.4.3",
    "glob": "^10.5.0",
    "typescript": "^5.3.3"
  }
}
