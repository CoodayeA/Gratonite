{
  "cli": { "version": ">= 5.0.0", "appVersionSource": "local" },
  "build": {
    "preview": {
      "android": { "buildType": "apk" },
      "ios": { "simulator": true },
      "channel": "preview"
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "buildConfiguration": "Release"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6759630780"
      },
      "android": {
        "track": "production",
        "releaseStatus": "completed"
      }
    }
  }
}
