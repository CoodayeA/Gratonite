{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gratonite Server",
  "version": "0.1.2",
  "identifier": "com.gratonite.server",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gratonite Server",
        "width": 600,
        "height": 500,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Gratonite Server"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["docker.io"]
      },
      "rpm": {
        "depends": ["docker-ce"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/CoodayeA/Gratonite/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFCQzNBNkU3MUZBMUVDRkQKUldUOTdLRWY1NmJERzNTekdxV3MwUDZsUXRLRzJMRzBPYWp6ZncxNUk3ZXZmMGo2VGhtVElLZXoK"
    }
  }
}
