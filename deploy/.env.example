# Database
DB_PASSWORD=change-this-to-a-strong-password
REDIS_PASSWORD=change-this-to-a-different-strong-password

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=
JWT_REFRESH_SECRET=
BULLBOARD_ADMIN_TOKEN=

# MFA Encryption Key (generate with: openssl rand -hex 32)
MFA_ENCRYPTION_KEY=

# SMTP (see docs/SMTP-CONFIGURATION.md)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# URLs
APP_URL=https://yourdomain.com
CORS_ORIGIN=https://yourdomain.com

# LiveKit (voice/video)
# If left blank, deploy scripts will generate key/secret on the server and
# default the URL to your existing API hostname.
LIVEKIT_URL=wss://api.yourdomain.com
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
