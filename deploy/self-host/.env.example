# ========================================
# GRATONITE INSTANCE CONFIGURATION
# ========================================
# Copy this file to .env and edit the values below.
# Or use the installer: curl -fsSL https://gratonite.chat/install | bash

# REQUIRED: Your instance's public domain (no https://, no trailing slash)
INSTANCE_DOMAIN=chat.example.com

# REQUIRED: Admin account (created on first run)
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-immediately

# REQUIRED: Database password (pick something strong, at least 16 chars)
DB_PASSWORD=change-me-to-something-random
REDIS_PASSWORD=change-me-to-a-different-random-secret
DB_USER=gratonite
DB_NAME=gratonite

# Secrets — auto-generated by setup container if left blank.
# The installer also generates these automatically.
JWT_SECRET=
JWT_REFRESH_SECRET=
MFA_ENCRYPTION_KEY=
BULLBOARD_ADMIN_TOKEN=

# ========================================
# FEDERATION
# ========================================
# Enabled by default — your instance connects to the Gratonite relay
# and can federate with other instances. No ports to open.

FEDERATION_ENABLED=true
FEDERATION_ALLOW_INBOUND=true
FEDERATION_ALLOW_OUTBOUND=true
FEDERATION_ALLOW_JOINS=true
FEDERATION_HUB_URL=https://gratonite.chat
# Set to true to register your instance with the Gratonite hub and sync remote guilds locally for the Discover page.
FEDERATION_DISCOVER_REGISTRATION=true
RELAY_ENABLED=true
RELAY_URL=wss://relay.gratonite.chat

# ========================================
# TLS MODE
# ========================================
# "internal" = self-signed cert (for local hosting)
# "you@email.com" = Let's Encrypt auto-cert (for server hosting)
TLS_MODE=internal

# Port overrides (for local hosting — avoids conflicts with existing services)
# HTTP_PORT=80
# HTTPS_PORT=443

# ========================================
# OPTIONAL SERVICES
# ========================================

# Voice/video — start with: docker compose --profile voice up -d
# LIVEKIT_URL=ws://livekit:7880
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=secret

# Email (for notifications, password resets)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=email-password
# SMTP_FROM=Gratonite <noreply@example.com>
