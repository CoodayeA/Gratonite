# ========================================
# GRATONITE INSTANCE CONFIGURATION
# ========================================
# Copy this file to .env and edit the values below.

# REQUIRED: Your instance's public domain (no https://, no trailing slash)
INSTANCE_DOMAIN=chat.example.com

# REQUIRED: Admin account (created on first run)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-immediately

# Optional: admin username (defaults to "admin" if not set)
# ADMIN_USERNAME=admin

# REQUIRED: Database password (pick something strong, at least 16 chars)
DB_PASSWORD=change-me-to-something-random
DB_USER=gratonite
DB_NAME=gratonite

# JWT secrets — leave blank! These are auto-generated by the setup container.
# Only set manually if you need to use specific values.
JWT_SECRET=
JWT_REFRESH_SECRET=

# Application URL (auto-derived from INSTANCE_DOMAIN — only set if you need a custom value)
# APP_URL=https://chat.example.com
# CORS_ORIGIN=https://chat.example.com

# ========================================
# FEDERATION (optional — disabled by default)
# ========================================

# Master switch: set to "true" to enable federation with other Gratonite instances
# FEDERATION_ENABLED=false

# Granular federation controls (only apply when FEDERATION_ENABLED=true):
# FEDERATION_ALLOW_INBOUND=true    # Accept federation requests from other instances
# FEDERATION_ALLOW_OUTBOUND=true   # Send federation requests to other instances
# FEDERATION_ALLOW_JOINS=true      # Allow remote users to join local guilds
# FEDERATION_ALLOW_REPLICATION=false # Enable guild replication features
# FEDERATION_DISCOVER_REGISTRATION=false # Register with Gratonite Discover directory

# Hub URL for Discover registration (defaults to https://gratonite.chat)
# Only change this if running a private federation network
# FEDERATION_HUB_URL=https://gratonite.chat

# ========================================
# OPTIONAL SERVICES
# ========================================

# Email (for notifications, password resets)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=email-password
# SMTP_FROM=Gratonite <noreply@example.com>

# LiveKit (voice/video) — start with: docker compose --profile voice up -d
# LIVEKIT_API_KEY=your-api-key
# LIVEKIT_API_SECRET=your-api-secret
# LIVEKIT_URL=ws://livekit:7880

# File upload limits
# MAX_UPLOAD_SIZE=25000000  # 25MB default

# ========================================
# ADVANCED (usually don't need to change)
# ========================================

# NODE_ENV=production
# PORT=4000
# LOG_LEVEL=info
