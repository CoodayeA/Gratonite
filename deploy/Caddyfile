# Main landing page
gratonite.chat {
    handle /api/* {
        reverse_proxy gratonite-api:4000
    }
    handle /socket.io/* {
        reverse_proxy gratonite-api:4000
    }
    handle /downloads/* {
        root * /srv/releases
        uri strip_prefix /downloads
        file_server
        header Access-Control-Allow-Origin *
    }
    handle /install {
        root * /srv
        rewrite * /install.sh
        file_server
        header Content-Type "text/plain; charset=utf-8"
    }
    # SPA + static app — must match the container that receives deploy/rsync (`gratonite-web` in docker-compose.production.yml).
    # Do not use a second web container here or production will stay on an old bundle (What's New, etc.).
    handle {
        reverse_proxy gratonite-web:80
    }
}

# API subdomain
api.gratonite.chat {
    handle /rtc* {
        reverse_proxy gratonite-livekit:7880
    }
    reverse_proxy gratonite-api:4000
}

# App subdomain — proxy API + Socket.IO like main host so same-origin /api/v1 works
app.gratonite.chat {
    handle /api/* {
        reverse_proxy gratonite-api:4000
    }
    handle /socket.io/* {
        reverse_proxy gratonite-api:4000
    }
    reverse_proxy gratonite-web:80
}

# Desktop app releases
releases.gratonite.chat {
    root * /srv/releases
    file_server
    header Access-Control-Allow-Origin *
}

# Relay — WebSocket federation relay
relay.gratonite.chat {
    reverse_proxy gratonite-relay:4100
}
