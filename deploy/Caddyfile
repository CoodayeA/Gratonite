# Main landing page (keep existing)
gratonite.chat {
    handle /downloads/* {
        root * /srv/releases
        uri strip_prefix /downloads
        file_server
        header Access-Control-Allow-Origin *
    }
    handle {
        reverse_proxy gratonite-web-1:80
    }
}

# API subdomain
api.gratonite.chat {
    reverse_proxy gratonite-api:4000
}

# App subdomain
app.gratonite.chat {
    reverse_proxy gratonite-web:80
}

# Desktop app releases
releases.gratonite.chat {
    root * /srv/releases
    file_server
    header Access-Control-Allow-Origin *
}
